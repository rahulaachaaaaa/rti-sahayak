# Copy to .env and fill in. .env is git-ignored.

# --- The global model switch (claude | deepseek) ---
RTI_PROVIDER=deepseek

# --- DeepSeek (bring-your-own key). Required when RTI_PROVIDER=deepseek. ---
DEEPSEEK_API_KEY=sk-...

# --- Claude via UiPath LLM Gateway. NO key here. ---
# Auth comes from your `uipath auth` session, not an env var.
# UIPATH_LLM_SERVICE is set by the SDK; leave unset locally unless instructed.
